# これをリポジトリ直下に fx-signal.env としてコピーし、値を記入する。
#   cp deploy/fx-signal.env.example fx-signal.env
# fx-signal.env は .gitignore 済み（コミットされない）。秘密情報をここに置く。

# Slack Incoming Webhook（必須。未設定だと通知は標準エラー出力に出るだけ）
SLACK_WEBHOOK_URL=

# リスク層用の Anthropic API キー（任意。未設定でも本体シグナルは動く）
ANTHROPIC_API_KEY=

# ダウMTFゲートの挙動を環境変数で上書き（コミット不要で切替。コメントアウトで既定値）。
#   DOW_GATE_ENABLED: ゲートのON/OFF（既定 true）
#   RANGE_BLOCKS:     上位足RANGEも抑制するか（既定 false＝逆行のみ抑制）
# 例: RANGE抑制(超保守・約5%通過)を試すなら RANGE_BLOCKS=true、ゲートを切るなら DOW_GATE_ENABLED=false
# DOW_GATE_ENABLED=true
# RANGE_BLOCKS=false
